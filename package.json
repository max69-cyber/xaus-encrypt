{
  "name": "xaus-encrypt",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev:backend": "cd backend && npx nodemon src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:7777 && cd electron && npx electron .",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build:frontend": "cd frontend && npm run build",
    "build:electron": "electron-builder",
    "build:backend": "cd backend && npm run build",
    "build": "npm run build:frontend && npm run build:backend && npm run build:electron"
  },
  "keywords": [],
  "author": "Maxim Samohvalov",
  "license": "ISC",
  "main": "electron/main.js",
  "dependencies": {
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2"
  },
  "build": {
    "appId": "com.xaus.encrypt",
    "productName": "fatEncryptor",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
